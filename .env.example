# Copy this file to `.env` and fill in values. The `.env` file is gitignored.

# Required. Generate a new key for each environment:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=

# Local development (omit or set True). For production use False.
DJANGO_DEBUG=True

# Comma-separated hostnames (no spaces). Example production: example.com,www.example.com
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,testserver

# ---------------------------------------------------------------------------
# Database (default: PostgreSQL when either block below is set; else SQLite)
# ---------------------------------------------------------------------------
# Option A — single URL (overrides individual POSTGRES_* variables when set):
#   DATABASE_URL=postgresql://USER:PASSWORD@127.0.0.1:5432/DB_NAME
# DATABASE_URL=

# Option B — separate variables (if DATABASE_URL is unset or empty):
#   POSTGRES_DB=your_database_name
#   POSTGRES_USER=postgres
#   POSTGRES_PASSWORD=
#   POSTGRES_HOST=127.0.0.1
#   POSTGRES_PORT=5432
# POSTGRES_DB=
