# Copy this file to `.env` and fill in values. The `.env` file is gitignored.

# Required. Generate a new key for each environment:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=

# Local development (omit or set True). For production use False.
DJANGO_DEBUG=True

# Comma-separated hostnames (no spaces). Example production: example.com,www.example.com
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,testserver
